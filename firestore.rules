rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- REUSABLE SECURITY PRIMITIVES ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // Auth tokens do not contain custom role claims in standard runtime setups.
    // To prevent identity spoofing, all identities are validated against request.auth.uid.
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- ENTITY SCHEMA VALIDATION BLUEPRINTS ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email'])
        && data.keys().size() <= 4
        && data.uid is string && data.uid.size() <= 128
        && data.email is string && data.email.size() <= 256;
    }

    function isValidAgentSubscription(data) {
      return data.keys().hasAll(['userId', 'agentId', 'planName', 'status', 'licenseKey', 'priceCharged'])
        && data.keys().size() <= 8
        && data.userId is string && data.userId.size() <= 128
        && data.agentId is string && data.agentId.size() <= 128
        && data.planName is string && data.planName.size() <= 128
        && data.status is string && data.status.size() <= 64
        && data.licenseKey is string && data.licenseKey.size() <= 128
        && data.priceCharged is string && data.priceCharged.size() <= 64;
    }

    function isValidTravelItinerary(data) {
      return data.keys().hasAll(['userId', 'destination', 'budget', 'durationDays', 'itineraryText'])
        && data.keys().size() <= 7
        && data.userId is string && data.userId.size() <= 128
        && data.destination is string && data.destination.size() <= 200
        && data.budget is string && data.budget.size() <= 64
        && data.durationDays is string && data.durationDays.size() <= 32
        && data.itineraryText is string && data.itineraryText.size() <= 50000;
    }

    function isValidStudyPlan(data) {
      return data.keys().hasAll(['userId', 'syllabus', 'planText'])
        && data.keys().size() <= 5
        && data.userId is string && data.userId.size() <= 128
        && data.syllabus is string && data.syllabus.size() <= 10000
        && data.planText is string && data.planText.size() <= 50000;
    }

    function isValidPatientTriage(data) {
      return data.keys().hasAll(['userId', 'patientName', 'symptoms', 'urgency', 'triageDetails'])
        && data.keys().size() <= 7
        && data.userId is string && data.userId.size() <= 128
        && data.patientName is string && data.patientName.size() <= 200
        && data.symptoms is string && data.symptoms.size() <= 10000
        && data.urgency is string && data.urgency.size() <= 64
        && data.triageDetails is string && data.triageDetails.size() <= 50000;
    }

    // EmailBilling Validator
    function isValidEmailBilling(data) {
      return data.keys().hasAll(['userId', 'clientName', 'amount', 'services', 'emailSubject', 'emailBody'])
        && data.keys().size() <= 8
        && data.userId is string && data.userId.size() <= 128
        && data.clientName is string && data.clientName.size() <= 200
        && data.amount is string && data.amount.size() <= 64
        && data.services is string && data.services.size() <= 2000
        && data.emailSubject is string && data.emailSubject.size() <= 500
        && data.emailBody is string && data.emailBody.size() <= 50000;
    }

    // --- COLLECTION RULE MATCHERS ---

    match /users/{userId} {
      allow get: if isSignedIn() && isOwner(userId) && isValidId(userId);
      allow create: if isSignedIn() && isOwner(userId) && isValidId(userId) && isValidUser(incoming());
      allow update: if isSignedIn() && isOwner(userId) && isValidId(userId) && isValidUser(incoming())
                       && incoming().uid == resource.data.uid;
      allow delete: if false;
    }

    match /agentSubscriptions/{subId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId) && isValidId(subId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isOwner(incoming().userId) && isValidId(subId) && isValidAgentSubscription(incoming());
      allow update: if isSignedIn() && isOwner(resource.data.userId) && isValidId(subId) && isValidAgentSubscription(incoming())
                       && incoming().userId == resource.data.userId
                       && incoming().agentId == resource.data.agentId;
      allow delete: if false;
    }

    match /travelItineraries/{itineraryId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId) && isValidId(itineraryId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isOwner(incoming().userId) && isValidId(itineraryId) && isValidTravelItinerary(incoming());
      allow update: if isSignedIn() && isOwner(resource.data.userId) && isValidId(itineraryId) && isValidTravelItinerary(incoming())
                       && incoming().userId == resource.data.userId;
      allow delete: if isSignedIn() && isOwner(resource.data.userId) && isValidId(itineraryId);
    }

    match /studyPlans/{planId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId) && isValidId(planId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isOwner(incoming().userId) && isValidId(planId) && isValidStudyPlan(incoming());
      allow update: if isSignedIn() && isOwner(resource.data.userId) && isValidId(planId) && isValidStudyPlan(incoming())
                       && incoming().userId == resource.data.userId;
      allow delete: if isSignedIn() && isOwner(resource.data.userId) && isValidId(planId);
    }

    match /patientTriages/{triageId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId) && isValidId(triageId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isOwner(incoming().userId) && isValidId(triageId) && isValidPatientTriage(incoming());
      allow update: if isSignedIn() && isOwner(resource.data.userId) && isValidId(triageId) && isValidPatientTriage(incoming())
                       && incoming().userId == resource.data.userId;
      allow delete: if isSignedIn() && isOwner(resource.data.userId) && isValidId(triageId);
    }

    match /emailBillings/{billingId} {
      allow get: if isSignedIn() && isOwner(resource.data.userId) && isValidId(billingId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isOwner(incoming().userId) && isValidId(billingId) && isValidEmailBilling(incoming());
      allow update: if isSignedIn() && isOwner(resource.data.userId) && isValidId(billingId) && isValidEmailBilling(incoming())
                       && incoming().userId == resource.data.userId;
      allow delete: if isSignedIn() && isOwner(resource.data.userId) && isValidId(billingId);
    }
  }
}
